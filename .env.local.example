# ========================================
# LADO ₿ — Variáveis de ambiente
# ========================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local

# ----- Clerk (Autenticação) -----
# Obter em: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# URLs de redirecionamento do Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/streak
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/streak

# ----- Supabase (Banco de dados) -----
# Obter em: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Resend (Envio de emails) -----
# Obter em: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@ladob.com.br

# ----- Beehiiv (Newsletter) -----
# Obter em: https://app.beehiiv.com → Settings → Integrations → API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
BEEHIIV_WEBHOOK_SECRET=

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
